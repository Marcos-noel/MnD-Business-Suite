APP_NAME="MnD Business Suite"
ENVIRONMENT="development"
DEBUG=true

API_V1_PREFIX="/api/v1"
ALLOWED_ORIGINS="http://localhost:3000"

DATABASE_URL="postgresql+asyncpg://mnd:mndpassword@localhost:5432/mnd"
REDIS_URL="redis://localhost:6379/0"
LOG_LEVEL="INFO"

JWT_ISSUER="mnd-business-suite"
JWT_AUDIENCE="mnd-users"
JWT_SECRET_KEY="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=14

PASSWORD_BCRYPT_ROUNDS=12

RATE_LIMIT_DEFAULT="100/minute"

FRONTEND_BASE_URL="http://localhost:3000"

# Comma-separated list, e.g. "country1,country2"
RESTRICTED_EXPORT_COUNTRIES=""

# Cookies
COOKIE_SECURE=false
COOKIE_SAMESITE="lax"

# FX Rates (Open Exchange Rates)
FX_API_BASE="https://openexchangerates.org/api"
FX_API_KEY=""
FX_REFRESH_MINUTES=60
